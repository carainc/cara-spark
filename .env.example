# Cara Spark — environment template.
# Copy to `.env` and fill in. BYO-key: bring your own provider keys.
# NEVER commit `.env` (gitignored). This file tracks NAMES only — no values.

# --- Core app ---
NODE_ENV=development
AUTH_URL=http://localhost:3000              # public base URL of the deploy
NEXTAUTH_URL=http://localhost:3000          # Auth.js callback base (mirror of AUTH_URL)
DATABASE_URL=                               # single Postgres + pgvector (RAG lives here; no separate vector DB)

# --- Auth.js (Google OAuth only — no Cognito, no GitHub) ---
AUTH_SECRET=                                # `openssl rand -base64 32`
AUTH_GOOGLE_ID=                             # Google OAuth web client id
AUTH_GOOGLE_SECRET=                         # Google OAuth web client secret
SUPERADMIN_EMAIL=                           # Google account seeded as bootstrap super-admin on first run

# --- LLM cascade (BYO) ---
ANTHROPIC_API_KEY=                          # Opus 4.8 — triage reasoning + cascade brain
OPENAI_API_KEY=                             # Realtime fallback rung

# --- Voice cascade (BYO) ---
DEEPGRAM_API_KEY=                           # STT + Aura TTS (EN + ES)
TELNYX_API_KEY=                             # SIP trunk / DID (standalone voice, T13)
LIVEKIT_URL=                                # standalone LiveKit (NOT the prod cara-realtime stack)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
VOICE_CONFIG_HMAC_SECRET=                   # signs the per-agent voice config + worker bearer token
LIVEKIT_NAT_1_TO_1_IP=                      # standalone EC2 ONLY: the Elastic IP (RTP media path). Empty locally; terraform sets it.

# --- Voice cascade tuning (optional; code has sensible defaults) ---
VOICE_AGENT_NAME=cara-spark-cascade         # explicit dispatch name (worker registers it; room_config.agents=[name])
VOICE_ROOM_PREFIX=voicephone-               # SIP dispatch room-name prefix the worker filters on
VOICE_APP_BASE_URL=                         # base URL the worker calls for /api/voice/decide + /post-call (defaults to AUTH_URL)
VOICE_LLM_MODEL=claude-opus-4-8             # cascade brain
VOICE_DEEPGRAM_MODEL=                       # override STT model (default: nova-3 en / nova-2 es)
VOICE_AURA_MODEL_EN=aura-2-andromeda-en     # English TTS voice
VOICE_AURA_MODEL_ES=aura-2-celeste-es       # Spanish TTS voice

# --- Cara data plane (default provider seam; swap = config, not code) ---
CARA_API_KEY=                               # ck_/sk_ — email/SMS/EHR proxy (T5)
CARA_TENANT_ID=                             # X-Tenant-ID header
CARA_API_BASE_URL=https://api.caramedical.com
