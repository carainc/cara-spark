# Cara Spark — environment template.
# Copy to `.env` and fill in. BYO-key: bring your own provider keys.
# NEVER commit `.env` (gitignored). This file tracks NAMES only — no values.

# --- Core app ---
NODE_ENV=development
AUTH_URL=http://localhost:3000              # public base URL of the deploy
NEXTAUTH_URL=http://localhost:3000          # Auth.js callback base (mirror of AUTH_URL)
DATABASE_URL=                               # single Postgres + pgvector (RAG lives here; no separate vector DB)

# --- Auth.js (Google OAuth only — no Cognito, no GitHub) ---
AUTH_SECRET=                                # `openssl rand -base64 32`
AUTH_GOOGLE_ID=                             # Google OAuth web client id
AUTH_GOOGLE_SECRET=                         # Google OAuth web client secret
SUPERADMIN_EMAIL=                           # account seeded as bootstrap super-admin on first run
SUPERADMIN_INITIAL_PASSWORD=                # optional: seeds a bcrypt password for credentials login (no-Google fallback)

# --- LLM cascade (BYO) ---
ANTHROPIC_API_KEY=                          # Opus 4.8 — triage reasoning + cascade brain
OPENAI_API_KEY=                             # Realtime fallback rung + referral-RAG embeddings (T12; text-embedding-3-small, 1536d)

# --- Voice cascade (BYO) ---
DEEPGRAM_API_KEY=                           # STT + Aura TTS (EN + ES)
TELNYX_API_KEY=                             # SIP trunk / DID (standalone voice, T13)
ALLOW_TELNYX_PROVISIONING=                  # HARD spend gate (tk-0024). Empty/false = OFF (default). Buying a DID costs $ and is a human gate (runbook) — ordering also needs an explicit per-call confirmedSpend. Leave empty unless running the documented provisioning runbook.
LIVEKIT_URL=                                # standalone LiveKit (NOT the prod cara-realtime stack)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
VOICE_CONFIG_HMAC_SECRET=                   # signs the per-agent voice config + worker bearer token
LIVEKIT_NAT_1_TO_1_IP=                      # standalone EC2 ONLY: the Elastic IP (RTP media path). Empty locally; terraform sets it. On the box also set NODE_IP to this value (below).
SIP_API_KEY=                                # livekit-sip credential — MUST equal the LiveKit server api_key (the key half of LIVEKIT_KEYS). Empty locally → compose uses the devkey placeholder.
SIP_API_SECRET=                             # livekit-sip credential — MUST equal the LiveKit server api_secret (the secret half of LIVEKIT_KEYS). Empty locally → devkey placeholder.
# --- LiveKit server overrides (standalone EC2 ONLY) — livekit-server does NOT expand ${} in its YAML,
#     so these are injected as real env vars via .env. LEAVE COMMENTED locally: an empty-but-present
#     value counts as "set" to the server and would wipe the YAML devkey / corrupt IP discovery. ---
# NODE_IP=                                  # the EC2 Elastic IP that LiveKit advertises for RTC/ICE (set NODE_IP = LIVEKIT_NAT_1_TO_1_IP). Replaces the never-expanded rtc.nat_1_to_1_ip.
# LIVEKIT_KEYS=                             # "<api_key>: <api_secret>" (note the space) — overrides config/livekit.yaml's devkey. Must match SIP_API_KEY/SIP_API_SECRET above.
DEMO_PHONE_DID=                             # read-only DID shown on the PHONE channel (demo fallback +14157180498)

# --- Voice cascade tuning (optional; code has sensible defaults) ---
VOICE_AGENT_NAME=cara-spark-cascade         # explicit dispatch name (worker registers it; room_config.agents=[name])
VOICE_ROOM_PREFIX=voicephone-               # SIP dispatch room-name prefix the worker filters on
VOICE_APP_BASE_URL=                         # base URL the worker calls for /api/voice/decide + /post-call (defaults to AUTH_URL)
VOICE_LLM_MODEL=claude-opus-4-8             # cascade brain
VOICE_DEEPGRAM_MODEL=                       # override STT model (default: nova-3 en / nova-2 es)
VOICE_AURA_MODEL_EN=aura-2-andromeda-en     # English TTS voice
VOICE_AURA_MODEL_ES=aura-2-celeste-es       # Spanish TTS voice

# --- Kiosk channel (T16; reuses VOICE_CONFIG_HMAC_SECRET above to sign device tokens) ---
# The kiosk box authenticates with a revocable device token (HMAC over agentId+deviceId via
# VOICE_CONFIG_HMAC_SECRET) — no user login (anonymous by design). No new server var is needed.
# These two are read ONLY by the no-hardware dev client `scripts/kiosk-sim.mjs` (also via --url/--agent):
KIOSK_URL=http://localhost:3000             # base URL the --sim client POSTs to (/api/kiosk/session)
KIOSK_AGENT_ID=demo-agent                   # published agent the simulated kiosk is bound to

# --- Cara data plane (default provider seam; swap = config, not code) ---
CARA_API_KEY=                               # ck_/sk_ — email/SMS/EHR proxy (T5)
CARA_TENANT_ID=                             # X-Tenant-ID header
CARA_API_BASE_URL=https://api.caramedical.com
# Provider seam selection (optional; defaults: comms=cara, ehr=elation). Swap = config, not code.
COMMS_VENDOR=                               # cara | twilio | sendgrid (only cara wired today)
EHR_VENDOR=                                 # elation | canvas | healthie
